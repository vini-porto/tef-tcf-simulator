# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Prisma datasource (SQLite in dev, Postgres in production — see CLAUDE.md)
DATABASE_URL="file:./dev.db"

# Which AI provider scores writing tasks: "anthropic" | "gemini"
# Only that provider's API key/model below need to be set.
AI_PROVIDER="anthropic"

# --- Anthropic (Claude) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_SCORING_MODEL="claude-opus-4-8"

# --- Google Gemini ---
# Get a free-tier key at https://aistudio.google.com/apikey
GEMINI_API_KEY="..."
GEMINI_SCORING_MODEL="gemini-flash-latest"
